@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Web.Pages.Account
@using Volo.Abp.Account.Localization
@model Volo.Abp.Account.Web.Pages.Account.LoginModel
@inject IHtmlLocalizer<AccountResource> L
@{
    Layout = null;  // Remove default layout for full control
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - SyriaStats</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            font-family: 'Montserrat', sans-serif;
        }

        .custom-login-container {
            min-height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f6f8f9;
            position: relative;
            overflow: hidden;
            margin: 0;
            padding: 0;
        }

        .watermark-top-left, .watermark-bottom-right {
            position: absolute;
            width: 757px;
            height: 761px;
            z-index: 1;
            pointer-events: none;
        }

        .watermark-top-left {
            top: -416px;
            left: -412px;
        }

        .watermark-bottom-right {
            bottom: -416px;
            right: -412px;
        }

        .login-card {
            position: relative;
            z-index: 10;
            display: flex;
            width: 1000px;
            max-width: 95%;
            height: 550px;
            background: white;
            border-radius: 0;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .card-left {
            position: relative;
            flex: 1.3;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .shape-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .left-content {
            position: absolute;
            top: 50%;
            left: 80px;
            transform: translateY(-50%);
            z-index: 2;
            text-align: center;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .windows-icon {
            width: 48px;
            margin-bottom: 24px;
        }

        .sys-title {
            font-size: 24px;
            font-weight: 500;
            margin: 0;
        }

        .card-right {
            flex: 1;
            padding: 4rem 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: white;
        }

        .login-title {
            text-align: center;
            font-size: 24px;
            margin-bottom: 24px;
            color: #1e293b;
            font-weight: bold;
        }

        .form-container {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .label {
            font-size: 14px;
            font-weight: 600;
            color: #1e293b;
        }

        .custom-input {
            width: 100%;
            padding: 0.85rem 1rem;
            border: 1px solid #d1d5db;
            color: #1e293b;
            border-radius: 6px;
            outline: none;
            font-size: 16px;
            transition: all 0.3s ease;
        }

            .custom-input:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
            }

        .password-wrapper {
            position: relative;
        }

        .eye-icon {
            position: absolute;
            right: 1.2rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            cursor: pointer;
            font-size: 1.1rem;
            width: 20px;
            height: 20px;
        }

        .btn-login {
            padding: 12px;
            border: none;
            font-size: 16px;
            cursor: pointer;
            margin-top: 24px;
            background: #1e293b;
            color: white;
            font-weight: 600;
            border-radius: 6px;
            transition: all 0.3s;
        }

            .btn-login:hover {
                opacity: 0.92;
            }
        @@media (max-width: 768px) {
            .login-card {
                flex-direction: column;
                height: auto;
            }

            .card-left {
                padding: 3rem 0;
            }

            .card-right {
                padding: 3rem 2rem;
            }
        }
    </style>
</head>
<body>
    <div class="custom-login-container theme-1">
        <!-- Watermarks (replace with your images) -->
        <img src="~/images/login/top-left.svg" alt="top left" class="watermark-top-left" />
        <img src="~/images/login/bottom-right.svg" alt="bottom right" class="watermark-bottom-right" />

        <!-- Login Card -->
        <div class="login-card">
            <!-- Left Panel -->
            <div class="card-left">
                <img src="~/images/login/Group 10780.svg" alt="shape overlay" class="shape-overlay" />
                <div class="left-content">
                    <img src="~/images/login/windows.svg" alt="windows" class="windows-icon" />
                    <h2 class="sys-title">SyriaStats System</h2>
                </div>
            </div>

            <!-- Right Panel (FORM) -->
            <div class="card-right">
                <h2 class="login-title">Login</h2>

                @if (Model.EnableLocalLogin)
                {
                    <form method="post">
                        <input asp-for="ReturnUrl" type="hidden" />
                        @* <input asp-for="ReturnUrlHash" type="hidden" /> *@

                        <div class="form-container">
                            <div class="input-group">
                                <label asp-for="LoginInput.UserNameOrEmailAddress" class="label">@L["UserName"]</label>
                                <input asp-for="LoginInput.UserNameOrEmailAddress" class="custom-input" />
                            </div>

                            <div class="input-group">
                                <label asp-for="LoginInput.Password" class="label">@L["Password"]</label>
                                <div class="password-wrapper">
                                    <input asp-for="LoginInput.Password" class="custom-input" id="PasswordInput" />
                                    <i class="fas fa-eye-slash eye-icon" id="TogglePasswordVisibility"></i>
                                </div>
                                <span asp-validation-for="LoginInput.Password" class="text-danger"></span>
                            </div>

                            <div class="input-group">
                                <label class="checkbox-label">
                                    <input asp-for="LoginInput.RememberMe" type="checkbox" /> @L["RememberMe"]
                                </label>
                            </div>

                            <button type="submit" name="Action" value="Login" class="btn-login">@L["Login"]</button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>

    <script>
        // Password toggle
        document.addEventListener("DOMContentLoaded", function () {
            const toggleIcon = document.getElementById("TogglePasswordVisibility");
            const passwordInput = document.getElementById("PasswordInput");
            if (toggleIcon && passwordInput) {
                toggleIcon.addEventListener("click", function () {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    toggleIcon.classList.toggle('fa-eye-slash');
                    toggleIcon.classList.toggle('fa-eye');
                });
            }
        });
    </script>
</body>
</html>